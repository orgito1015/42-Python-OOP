# The Matrix - Oracle Configuration Example
# Copy this file to .env and fill in your own values.
# Never commit the .env file with real secrets to version control!

# Application mode: "development" or "production"
MATRIX_MODE=development

# Database connection string
DATABASE_URL=sqlite:///matrix_local.db

# Secret key for external API services
API_KEY=your_api_key_here

# Logging verbosity: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# Resistance network endpoint
ZION_ENDPOINT=http://localhost:8080/zion
